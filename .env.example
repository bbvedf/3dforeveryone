# ============================================================
# CONFIGURACIÓN DE LA APLICACIÓN - Tienda 3D API
# Copia este fichero a .env y rellena los valores:
# cp .env.example .env
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=user
POSTGRES_PASSWORD=pon-aqui-una-password-segura
POSTGRES_DB=db

# --- Conexión completa (usada por FastAPI) ---
# IMPORTANTE: el host es 'db' dentro de Docker, 'localhost' en local
DATABASE_URL=postgresql://user:pon-aqui-una-password-segura@db:5432/db

# --- Seguridad JWT ---
# Genera una clave fuerte con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esta-clave-por-una-aleatoria-y-segura
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Servidor ---
HOST=0.0.0.0
PORT=8000
DEBUG=True
